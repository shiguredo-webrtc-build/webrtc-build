{
    "name": "raspberry-pi-os_armv8",
    "arch": "arm64",
    "triplet": "aarch64-linux-gnu",
    "packages": [
        "libc6-dev",
        "libstdc++-11-dev",
        "libasound2-dev",
        "libpulse-dev",
        "libudev-dev",
        "libexpat1-dev",
        "libnss3-dev",
        "python3-dev",
        "libgtk-3-dev",
        "libsdl2-dev",
        "libraspberrypi-bin",
        "libraspberrypi-dev"
    ],
    "repositories": [
        {
            "url": "https://deb.debian.org/debian",
            "suite": "bookworm",
            "components": ["main"],
            "signed_by": "/usr/share/keyrings/debian-archive-keyring.gpg"
        },
        {
            "url": "https://archive.raspberrypi.com/debian",
            "suite": "bookworm",
            "components": ["main"],
            "signed_by": "keyrings/raspberrypi-archive-keyring.asc"
        }
    ]
}
