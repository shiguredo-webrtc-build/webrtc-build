+std::unique_ptr<SSLIdentity> JavaToNativeSSLIdentityFromPEMChainStrings(
+    JNIEnv* jni,
+    const std::string& private_key,
+    const std::string& certificate_chain) {
+  std::unique_ptr<SSLIdentity> identity =
+      SSLIdentity::CreateFromPEMChainStrings(private_key, certificate_chain);
+  if (identity == nullptr) {
+    jni->ThrowNew(
+        jni_zero::GetClass(jni, "java/lang/IllegalArgumentException").obj(),
+        "Invalid TURN-TLS client certificate or private key.");
+  }
+  return identity;
+}
