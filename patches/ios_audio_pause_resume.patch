+bool VoiceProcessingAudioUnit::SetBypassVoiceProcessing(bool enable) {
+  should_bypass_voice_processing_ = enable;
+  if (state_ < kInitialized || !vpio_unit_) {
+    return true;
+  }
+  return ApplyBypassVoiceProcessing();
+}
+
+bool VoiceProcessingAudioUnit::IsBypassVoiceProcessingEnabled() const {
+  if (state_ < kInitialized || !vpio_unit_) {
+    return false;
+  }
+
+  UInt32 bypass_enabled = 0;
+  UInt32 size = sizeof(bypass_enabled);
+  OSStatus result = AudioUnitGetProperty(vpio_unit_,
+                                         kAUVoiceIOProperty_BypassVoiceProcessing,
+                                         kAudioUnitScope_Global,
+                                         kInputBus,
+                                         &bypass_enabled,
+                                         &size);
+  if (result != noErr) {
+    RTCLogError(@"Failed to get bypass voice processing state. Error=%ld",
+                (long)result);
+    return false;
+  }
+  return bypass_enabled == 1;
+}
+
+bool VoiceProcessingAudioUnit::ApplyBypassVoiceProcessing() {
+  RTC_DCHECK(vpio_unit_);
+  UInt32 toggle = should_bypass_voice_processing_ ? 1 : 0;
+  OSStatus result = AudioUnitSetProperty(vpio_unit_,
+                                         kAUVoiceIOProperty_BypassVoiceProcessing,
+                                         kAudioUnitScope_Global,
+                                         kInputBus,
+                                         &toggle,
+                                         sizeof(toggle));
+  if (result != noErr) {
+    RTCLogError(@"Failed to set bypass voice processing. enabled=%d, Error=%ld",
+                should_bypass_voice_processing_,
+                (long)result);
+    return false;
+  }
+  RTCLog(@"Set bypass voice processing. enabled=%d",
+         should_bypass_voice_processing_);
+  return true;
+}
