diff --git a/sdk/android/api/org/webrtc/AudioTrack.java b/sdk/android/api/org/webrtc/AudioTrack.java
index 725f371..f95d9bf 100644
--- a/sdk/android/api/org/webrtc/AudioTrack.java
+++ b/sdk/android/api/org/webrtc/AudioTrack.java
@@ -12,12 +12,48 @@ package org.webrtc;
 
 import org.jni_zero.NativeMethods;
 
-/** Java wrapper for a C++ AudioTrackInterface */
+import java.util.IdentityHashMap;
+
+/** Java wrapper for a C++ AudioTrackInterface.
+ *  スレッドセーフに AudioTrackSink の追加と削除を行う。
+ *  sinks は IdentityHashMap で管理し、同一インスタンスの重複登録を防ぐ。
+ */
 public class AudioTrack extends MediaStreamTrack {
   public AudioTrack(long nativeTrack) {
     super(nativeTrack);
   }
 
+  private final IdentityHashMap<AudioTrackSink, Long> sinks = new IdentityHashMap<>();
+
+  public void addSink(AudioTrackSink sink) {
+    if (sink == null) {
+      throw new IllegalArgumentException("AudioTrackSink must not be null");
+    }
+    if (!sinks.containsKey(sink)) {
+      final long nativeSink = AudioTrackJni.get().wrapSink(sink);
+      sinks.put(sink, nativeSink);
+      AudioTrackJni.get().addSink(getNativeAudioTrack(), nativeSink);
+    }
+  }
+
+  public void removeSink(AudioTrackSink sink) {
+    final Long nativeSink = sinks.remove(sink);
+    if (nativeSink != null) {
+      AudioTrackJni.get().removeSink(getNativeAudioTrack(), nativeSink);
+      AudioTrackJni.get().freeSink(nativeSink);
+    }
+  }
+
+  @Override
+  public void dispose() {
+    for (long nativeSink : sinks.values()) {
+      AudioTrackJni.get().removeSink(getNativeAudioTrack(), nativeSink);
+      AudioTrackJni.get().freeSink(nativeSink);
+    }
+    sinks.clear();
+    super.dispose();
+  }
+
   /** Sets the volume for the underlying MediaSource. Volume is a gain value in the range
    *  0 to 10.
    */
@@ -33,5 +72,13 @@ public class AudioTrack extends MediaStreamTrack {
   @NativeMethods
   interface Natives {
     void setVolume(long track, double volume);
+
+    void addSink(long audioTrackHandle, long sinkHandle);
+
+    long wrapSink(AudioTrackSink sink);
+
+    void removeSink(long audioTrackHandle, long sinkHandle);
+
+    void freeSink(long sink);
   }
 }
