-  jni->SetByteArrayRegion(
-      jni_buffer.obj(), 0, cert_der_buffer.size(),
-      reinterpret_cast<const jbyte*>(cert_der_buffer.data()));
-
+      SerializeCertificate(jni, certificate);
   return Java_SSLCertificateVerifier_verify(jni, ssl_certificate_verifier_,
                                             jni_buffer);
 }
 
+bool SSLCertificateVerifierWrapper::VerifyChain(const SSLCertChain& chain) {
+  if (chain.GetSize() == 0) {
+    return false;
+  }
+  JNIEnv* jni = AttachCurrentThreadIfNeeded();
+  ScopedJavaLocalRef<jobjectArray> jni_chain =
+      SerializeCertificateChain(jni, chain);
+  return Java_SSLCertificateVerifier_verifyChain(
+      jni, ssl_certificate_verifier_, jni_chain);
+}
